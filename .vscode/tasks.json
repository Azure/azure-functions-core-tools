{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/Func/Func.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/test/Func.Tests/Func.Tests.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/src/Func/Func.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "deploy-workload-for-debug",
            "command": "pwsh",
            "type": "process",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/eng/scripts/deploy-workload-for-debug.ps1",
                "-WorkloadProject",
                "${input:debugWorkloadProject}",
                "-WorkloadsHome",
                "${workspaceFolder}/.debug-workloads"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-and-deploy-workload",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build",
                "deploy-workload-for-debug"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "debugWorkloadProject",
            "type": "pickString",
            "description": "Workload csproj to rebuild and redeploy before launch",
            "options": [
                "${workspaceFolder}/src/Workloads/Stacks/Node/Workloads.Node.csproj",
                "${workspaceFolder}/src/Workloads/Stacks/Python/Workloads.Python.csproj",
                "${workspaceFolder}/src/Workloads/Stacks/DotNet/Workloads.DotNet.csproj",
                "${workspaceFolder}/src/Workloads/Stacks/Go/Workloads.Go.csproj"
            ]
        }
    ]
}