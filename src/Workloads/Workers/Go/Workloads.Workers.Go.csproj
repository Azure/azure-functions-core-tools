<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Title>Go Worker</Title>
    <Description>Azure Functions CLI content workload that ships the Go worker assets (static worker config).</Description>
    <PackAsWorkload>true</PackAsWorkload>
    <WorkloadKind>content</WorkloadKind>
    <WorkloadAlias>go-worker</WorkloadAlias>
    <PackageTags>func-worker</PackageTags>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="content/workers/native/worker.config.json" Pack="true" PackagePath="tools/any/" />
  </ItemGroup>

</Project>
