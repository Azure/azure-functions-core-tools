[
  {
    "id": "trigger-functionName",
    "name": "trigger-functionName",
    "value": "string",
    "label": "$trigger_functionName_label",
    "help": "$trigger_functionName_help",
    "defaultValue": "http",
    "validators": [
      {
        "expression": "^[a-zA-Z][a-zA-Z0-9_]{0,126}[a-zA-Z0-9]$",
        "errorText": "$trigger_functionName_errorText"
      }
    ]
  }
]
