<Project>

  <!--
    The DotNetAzd templates workload has no extension-bundle dependency
    (see proposed/templates-workload-spec.md §4.4.3 for the analogous
    DotNet rationale). The pkg version follows its own SemVer cadence and
    there is no bundle channel / prerelease-label axis.

      $(VersionPrefix)   Workload pkg version (3-part SemVer).
  -->

  <PropertyGroup>
    <VersionPrefix>1.0.0</VersionPrefix>
  </PropertyGroup>

</Project>
