<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifiers>$(_CliRuntimeIdentifiers)</RuntimeIdentifiers>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <Title>Functions Host</Title>
    <Description>Azure Functions CLI content workload that ships the Azure Functions host.</Description>
    <!-- The pinned WebHost package still exposes IWebHost; remove this when the package exposes the IHost-based entry point from dev. -->
    <NoWarn>$(NoWarn);ASPDEPR008</NoWarn>
    <PackAsWorkload>true</PackAsWorkload>
    <WorkloadKind>content</WorkloadKind>
    <WorkloadAlias>host</WorkloadAlias>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Azure.Functions.Cli.Workloads.Host.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Azure.WebJobs.Script.WebHost" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="System.Diagnostics.EventLog" />
    <PackageReference Update="@(PackageReference)" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Include="workers\workers.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Import Project="$(MSBuildThisFileDirectory)Build.Inner.targets" />

</Project>
