<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Title>.NET Stack</Title>
    <Description>Azure Functions CLI tooling for .NET (C#, F#) projects.</Description>
    <PackAsWorkload>true</PackAsWorkload>
    <WorkloadKind>workload</WorkloadKind>
    <WorkloadAlias>dotnet</WorkloadAlias>
    <IsPublishable>true</IsPublishable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Azure.Functions.Cli.Workloads.DotNet.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(SrcRoot)Abstractions/Abstractions.csproj" />
  </ItemGroup>

</Project>
