<Project>

  <PropertyGroup>
    <!-- Always suppress these warnings -->
    <NoWarn>$(NoWarn);NU1507;NU1701;NU5118;SA0001</NoWarn>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU5123</WarningsNotAsErrors>

    <!-- Nuget audit failures all break the build in CI: NU1902 (moderate), NU1903 (high), NU1904 (critical). -->
    <!-- Outside CI they remain warnings to keep local dev unblocked. -->
    <WarningsNotAsErrors Condition="'$(CI)' == 'false'">$(WarningsNotAsErrors);NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <WarningsAsErrors Condition="'$(CI)' == 'true'">$(WarningsAsErrors);NU1902;NU1903;NU1904</WarningsAsErrors>

    <!-- TreatWarningsAsErrors true only on CI -->
    <TreatWarningsAsErrors>$(CI)</TreatWarningsAsErrors>

    <!-- NuGet audit settings -->
    <NuGetAuditLevel>moderate</NuGetAuditLevel> <!-- warn on moderate severity only. -->
    <NuGetAuditMode>all</NuGetAuditMode> <!-- audit transitive dependencies. -->
  </PropertyGroup>

  <!-- Suppress audit advisories that don't apply to net8.0 builds. -->
  <ItemGroup>
    <!--
      System.Private.Uri 4.3.0 is dragged in by the legacy runtime.* metapackages (runtime.any.System.Runtime,
      runtime.unix.System.Runtime.Extensions). On net8.0 the actual Uri code lives in the runtime, not in this
      reference assembly, so the advisories below do not affect the shipped binary. There is no patched 4.x
      release of System.Private.Uri to upgrade to.

      TODO: Remove these suppressions once the host / middleware bumps in #4850 land on main. Those
      upgrades drop the legacy 4.3.x runtime.* metapackage chain entirely, so the transitive disappears.
    -->
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-x5qj-9vmx-7g6g" />
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-xhfc-gr8f-ffwc" />
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-5f2m-466j-3848" />

    <!--
      OpenTelemetry 1.14.0 advisories. These packages are pulled in transitively by the host
      (Microsoft.Azure.WebJobs.Script.WebHost via Azure.Monitor.OpenTelemetry.Exporter). The host
      pins the entire OT family at 1.14.0 in its own Directory.Packages.props, so overriding here
      via CPM transitive pinning would force the host to load an OT version it was not built and
      tested against. Suppress until host bumps to 1.15.x.

      TODO: Remove these once https://github.com/Azure/azure-functions-host/issues/11773 lands and
      we pick up a new Microsoft.Azure.WebJobs.Script.WebHost release.
    -->
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-g94r-2vxg-569j" />
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-4625-4j76-fww9" />
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-mr8r-92fq-pj8p" />
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-q834-8qmm-v933" />
  </ItemGroup>

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DisableImplicitNamespaceImports>true</DisableImplicitNamespaceImports>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <!-- We still need this config to set xmlHeader = false & documentation settings -->
  <ItemGroup>
    <AdditionalFiles Include="$(RepoRoot)stylecop.json" Link="stylecop.json" />
  </ItemGroup>

  <Import Project="$(MSBuildThisFileDirectory)Release.props" />

</Project>
