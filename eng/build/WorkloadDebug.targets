<Project>

  <!--
    DeployForDebug: build the workload and copy the freshly built assembly +
    PDB into an installed workload home so a single F5 (or
    `dotnet build -t:DeployForDebug`) gives you breakpoints in workload
    source.

    Lives at the build layer instead of in an IDE-specific script so VS Code,
    Visual Studio, Rider, and the CLI all consume the same logic.

    Resolution order for the workload home:
      1. $(FuncCliWorkloadsHome) MSBuild property (-p:FuncCliWorkloadsHome=...)
      2. FUNC_CLI_WORKLOADS_HOME environment variable
      3. $(RepoRoot).debug-workloads/ (matches the VS Code launch config)

    By default, fails fast if the workload isn't installed in the resolved
    home: the install state of the home is part of what you're debugging
    ("what does the CLI do when only X is installed?"), so we don't silently
    mutate it. Pass -p:FuncCliEnsureWorkloadInstalled=true to opt in to a
    one-time pack and `func workload install` step when the install is missing.

    No-op for non-workload projects so it's safe to invoke from a solution-wide
    build target.
  -->
  <Target Name="DeployForDebug" DependsOnTargets="Build">

    <Message Condition="'$(PackageType)' != 'FuncCliWorkload'"
             Importance="High"
             Text="DeployForDebug: skipping '$(MSBuildProjectName)' (PackageType='$(PackageType)', expected 'FuncCliWorkload')." />

    <PropertyGroup Condition="'$(PackageType)' == 'FuncCliWorkload'">
      <_DeployForDebugHome Condition="'$(FuncCliWorkloadsHome)' != ''">$(FuncCliWorkloadsHome)</_DeployForDebugHome>
      <_DeployForDebugHome Condition="'$(_DeployForDebugHome)' == ''">$(FUNC_CLI_WORKLOADS_HOME)</_DeployForDebugHome>
      <_DeployForDebugHome Condition="'$(_DeployForDebugHome)' == ''">$(RepoRoot).debug-workloads</_DeployForDebugHome>
      <_DeployForDebugHome>$([System.IO.Path]::GetFullPath('$(_DeployForDebugHome)'))</_DeployForDebugHome>
      <!-- func workload install normalises the package id to lowercase on disk. -->
      <_DeployForDebugPackageIdLower>$(PackageId.ToLowerInvariant())</_DeployForDebugPackageIdLower>
      <_DeployForDebugTargetDir>$(_DeployForDebugHome)/workloads/$(_DeployForDebugPackageIdLower)/$(PackageVersion)/tools/any</_DeployForDebugTargetDir>
      <_DeployForDebugInstallVersionDir>$(_DeployForDebugHome)/workloads/$(_DeployForDebugPackageIdLower)/$(PackageVersion)</_DeployForDebugInstallVersionDir>
      <_DeployForDebugFuncDll>$(RepoRoot)out/bin/Func/debug/func.dll</_DeployForDebugFuncDll>
      <_DeployForDebugPackOutput>$(_DeployForDebugHome)/.pack-cache</_DeployForDebugPackOutput>
      <_DeployForDebugNupkg>$(_DeployForDebugPackOutput)/$(PackageId).$(PackageVersion).nupkg</_DeployForDebugNupkg>
      <_DeployForDebugNeedsInstall Condition="!Exists('$(_DeployForDebugInstallVersionDir)')">true</_DeployForDebugNeedsInstall>
    </PropertyGroup>

    <!--
      Not installed and the caller didn't opt in: bail with a message that
      hands them both recipes (auto-install via the property, or manual
      install via `func workload install`).
    -->
    <Error Condition="'$(_DeployForDebugNeedsInstall)' == 'true' AND '$(FuncCliEnsureWorkloadInstalled)' != 'true'"
           Text="DeployForDebug: '$(PackageId)' $(PackageVersion) is not installed at '$(_DeployForDebugInstallVersionDir)'. Either rerun with -p:FuncCliEnsureWorkloadInstalled=true to auto-install (the &quot;auto-install&quot; VS Code launch config does this), or run `func workload install &lt;nupkg-or-id&gt;` against the same home first." />

    <Error Condition="'$(_DeployForDebugNeedsInstall)' == 'true' AND '$(FuncCliEnsureWorkloadInstalled)' == 'true' AND !Exists('$(_DeployForDebugFuncDll)')"
           Text="DeployForDebug: '$(PackageId)' isn't installed yet and func.dll wasn't found at '$(_DeployForDebugFuncDll)'. Build Func.csproj first." />

    <MSBuild Condition="'$(_DeployForDebugNeedsInstall)' == 'true' AND '$(FuncCliEnsureWorkloadInstalled)' == 'true'"
             Projects="$(MSBuildProjectFullPath)"
             Targets="Pack"
             Properties="Configuration=$(Configuration);PackageOutputPath=$(_DeployForDebugPackOutput)" />

    <Exec Condition="'$(_DeployForDebugNeedsInstall)' == 'true' AND '$(FuncCliEnsureWorkloadInstalled)' == 'true'"
          Command='dotnet "$(_DeployForDebugFuncDll)" workload install "$(_DeployForDebugNupkg)" --force'
          EnvironmentVariables="FUNC_CLI_WORKLOADS_HOME=$(_DeployForDebugHome)" />

    <Error Condition="'$(_DeployForDebugNeedsInstall)' == 'true' AND '$(FuncCliEnsureWorkloadInstalled)' == 'true' AND !Exists('$(_DeployForDebugInstallVersionDir)')"
           Text="DeployForDebug: install of '$(_DeployForDebugNupkg)' didn't produce '$(_DeployForDebugInstallVersionDir)'. Check the func workload install output above." />

    <Message Condition="'$(PackageType)' == 'FuncCliWorkload' AND '$(_DeployForDebugNeedsInstall)' != 'true'"
             Importance="High"
             Text="DeployForDebug: '$(PackageId)' $(PackageVersion) already installed at $(_DeployForDebugInstallVersionDir)." />

    <ItemGroup Condition="'$(PackageType)' == 'FuncCliWorkload' AND '$(IncludeBuildOutput)' != 'false'">
      <_DeployForDebugPayload Include="$(TargetPath)" />
      <_DeployForDebugPayload Include="$(TargetDir)$(TargetName).pdb" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
    </ItemGroup>

    <Copy Condition="'$(PackageType)' == 'FuncCliWorkload' AND '@(_DeployForDebugPayload)' != ''"
          SourceFiles="@(_DeployForDebugPayload)"
          DestinationFolder="$(_DeployForDebugTargetDir)"
          SkipUnchangedFiles="false" />

    <Message Condition="'$(PackageType)' == 'FuncCliWorkload' AND '@(_DeployForDebugPayload)' != ''"
             Importance="High"
             Text="DeployForDebug: copied @(_DeployForDebugPayload->'%(Filename)%(Extension)', ', ') -> $(_DeployForDebugTargetDir)" />
  </Target>

</Project>


