<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements applied during macOS code signing under the Hardened Runtime.
  Submitted to ESRP alongside the binary in the signing zip.

  - allow-jit: RyuJIT writes executable memory at runtime; required for any
    .NET binary that uses the JIT (i.e. anything not fully AOT-compiled).
  - allow-unsigned-executable-memory: belt-and-suspenders for tiered JIT and
    R2R fixup scenarios that also touch executable memory.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
  </dict>
</plist>
